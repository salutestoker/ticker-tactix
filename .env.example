NEWSLETTER_TEST_EMAILS=
QUEUE_CONNECTION=database
CATALOG_SPREADSHEET_DISK=
CATALOG_SPREADSHEET_DIRECTORY=
# Scheduled CSV imports are forced to production only in routes/console.php.
CATALOG_SPREADSHEET_SCHEDULE_ENABLED=false

CACHE_STORE=database
# CACHE_PREFIX=

MEMCACHED_HOST=127.0.0.1

