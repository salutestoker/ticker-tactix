APP_NAME="Ticker Tactix"
APP_ENV=local
APP_KEY=
APP_DEBUG=true
APP_URL=http://localhost:8081
APP_PORT=8081
VITE_PORT=5174

APP_LOCALE=en
APP_FALLBACK_LOCALE=en
APP_FAKER_LOCALE=en_US

APP_MAINTENANCE_DRIVER=file
# APP_MAINTENANCE_STORE=database

# PHP_CLI_SERVER_WORKERS=4

BCRYPT_ROUNDS=12

LOG_CHANNEL=stack
LOG_STACK=single
LOG_DEPRECATIONS_CHANNEL=null
LOG_LEVEL=debug

DB_CONNECTION=mysql
DB_HOST=mysql
DB_PORT=3306
DB_DATABASE=ticker_tactix
DB_USERNAME=sail
DB_PASSWORD=password
FORWARD_DB_PORT=3307

SESSION_DRIVER=database
SESSION_LIFETIME=120
SESSION_ENCRYPT=false
SESSION_PATH=/
SESSION_DOMAIN=null

BROADCAST_CONNECTION=log
FILESYSTEM_DISK=local
PUBLIC_STORAGE_URL=/storage
CATALOG_MEDIA_DISK=
# Laravel Cloud injects FILESYSTEM_DISK when a bucket is attached. Set these only if overriding that disk.
PLAYBOOK_LOGO_DISK=public
PLAYBOOK_LOGO_DIRECTORY=playbook-logos
MODULE_IMAGE_DISK=public
MODULE_IMAGE_DIRECTORY=module-images
MODULE_BANNER_IMAGE_DIRECTORY=module-banner-images
